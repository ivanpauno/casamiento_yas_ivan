---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Counter from '../components/Countdown.astro';
import Location from '../components/Location.astro';
import Carousel from '../components/Carousel.astro';
import DressCode from '../components/DressCode.astro';
import Gift from '../components/Gift.astro';
import RSVP from '../components/RSVP.astro';

const eventDate = '2026-12-31T18:00:00';
---

<Layout>
	<Header title="Nos casamos Yasmin e Ivan" subtitle="¡Acompáñanos en nuestro día!" />

	<section class="grid grid-cols-2">
		<Counter date={eventDate} />
		<Location place="Iglesia San José, Ciudad" mapQuery={encodeURIComponent('Iglesia San José Ciudad')} />
	</section>

	<section>
		<Carousel images={[ '/Invitación De Boda Anillos De Oro Florales Stock de ilustración - Ilustración de delicado, scrapbook_ 4666282.jpeg', '/favicon.svg', '/favicon.ico' ]} />
	</section>

	<section class="grid grid-cols-2">
		<DressCode title="Dress-code" description="Formal — traje oscuro / vestido de cóctel. Colores sugeridos: pasteles y tonos neutros." />
		<Gift alias="alias@banco" message="Si preferís transferir, usar alias y avisarnos por mensaje." />
	</section>

	<section>
		<RSVP formAction="https://formspree.io/f/your-form-id" />
	</section>
</Layout>
