<div class="card">
  <h1>¡Confirma tu presencia!</h1>
  <form id="myForm">
    <div class="field">
      <label for="nombre">Nombre Completo</label>
      <input name="entry.1777691097" id="nombre" required/>
    </div>
    <div class="field">
      <label for="n_adultos">Cantidad Adultos</label>
      <input name="entry.1572898739" id="n_adultos" type="number" required/>
    </div>
    <div class="field">
      <label for="n_menores">Cantidad Menores (hasta 10 años)</label>
      <input name="entry.384189581" id="n_menores" type="number" />
    </div>
    <div class="field">
      <label for="restricciones">Restricciones Alimentarias</label>
      <select name="entry.1067818" id="restricciones">
        <option value="Ninguna">Ninguna</option>
        <option value="Celiaco">Celiaco</option>
        <option value="Vegetariano">Vegetariano</option>
        <option value="Vegano">Vegano</option>
        <option value="__other_option__">Otro</option>
      </select>
    </div>
    <div class="field" id="restricciones-otro-container" style="display:none;">
      <label for="restricciones-otro">Especificar otra restricción</label>
      <input name="entry.1067818.other_option_response" id="restricciones-otro" placeholder="Detalle la restricción" />
    </div>
    <div class="field submit-row">
      <button type="submit">Enviar</button>
    </div>
  </form>
  <script>
    const restriccionesSelect = document.getElementById('restricciones');
    const otroContainer = document.getElementById('restricciones-otro-container');
    const restriccionesOtroInput = document.getElementById('restricciones-otro');
    restriccionesSelect?.addEventListener('change', () => {
      const isOther = restriccionesSelect.value === '__other_option__';
      if (isOther) {
        otroContainer.style.display = 'block';
        restriccionesOtroInput?.setAttribute('required', 'required');
        restriccionesOtroInput?.removeAttribute('aria-hidden');
        restriccionesOtroInput?.focus();
      } else {
        otroContainer.style.display = 'none';
        restriccionesOtroInput?.removeAttribute('required');
        restriccionesOtroInput?.setAttribute('aria-hidden', 'true');
      }
    });
  </script>
  <script>
    document.getElementById('myForm').addEventListener('submit', function(e) {
        e.preventDefault(); // Prevents the redirect page change

        const form = this;

        function showDialogMessage(text) {
          const dialog = document.getElementById('rsvpDialog');
          const msg = document.getElementById('rsvpDialogMessage');
          if (msg) msg.textContent = text;
          if (dialog && typeof dialog.showModal === 'function') dialog.showModal();
          else if (dialog && typeof dialog.style !== 'undefined') dialog.style.display = 'block';
        }

        const formData = new FormData(form);
        const googleFormUrl = "https://docs.google.com/forms/d/e/1FAIpQLSdm7Yab1LKQO7hO5jjZpGL3qbDHN-WKUDuxtWAE2L4Xfitzug/formResponse";

        fetch(googleFormUrl, {
            method: 'POST',
            body: formData,
            mode: 'no-cors' // Crucial to bypass cross-origin browser security blocks
        })
        .then(() => {
            showDialogMessage('Gracias por tu respuesta!');
            form.reset();
        })
        .catch(error => {
            showDialogMessage('Ocurrió un error. Por favor intentá de nuevo.');
            console.error('Error:', error);
        });
    });
  </script>

  <dialog id="rsvpDialog" class="rsvp-dialog">
    <div class="rsvp-dialog-content">
      <p id="rsvpDialogMessage">Mensaje</p>
      <div class="rsvp-dialog-actions">
        <button id="rsvpDialogClose">Cerrar</button>
      </div>
    </div>
  </dialog>

  <style>
    .card {
      display: flex;
      flex-direction: column;
      gap: clamp(10px, 2vw, 30px);
      padding: clamp(10px, 2vw, 30px);
      justify-content: center;
      align-items: center;
      text-align: center;
      background: var(--card-gradient);
    }
    .card h1 {
      margin: 0;
      font-size: clamp(1rem, 14vw, 8svh);
      line-height: 1;
    }
    .form-grid {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      width: min(100%, 560px);
      align-items: stretch;
    }
    .field {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
      width: 100%;
    }
    .field label {
      font-size: clamp(1rem, 3vw, 1.4rem);
      text-align: left;
    }
    .field input,
    .field select {
      width: 90%;
      padding: 0.9rem 1rem;
      border: 1px solid var(--border);
      font-size: clamp(1rem, 3vw, 1.2rem);
      background: white;
    }
    .submit-row {
      display: flex;
      justify-content: center;
      width: 100%;
      padding: 1rem;
    }
    .submit-row button {
      width: 100%;
      padding: 1rem;
      border: none;
      background: var(--action-bg);
      font-size: clamp(1rem, 3vw, 1.2rem);
      cursor: pointer;
    }
    .submit-row button:hover {
      opacity: 0.95;
    }
    /* RSVP dialog styles */
    .rsvp-dialog::backdrop {
      background: rgba(0,0,0,0.35);
    }
    .rsvp-dialog {
      border: none;
      padding: 0;
    }
    .rsvp-dialog-content {
      background: #f9f9f2;
      color: #082006;
      padding: 1.25rem 1.5rem;
      border-radius: 12px;
      min-width: 260px;
      text-align: center;
    }
    .rsvp-dialog-actions {
      margin-top: 1rem;
      display: flex;
      justify-content: center;
    }
    .rsvp-dialog-actions button {
      background: white;
      color: #082006;
      border: none;
      padding: 0.6rem 1rem;
      border-radius: 8px;
      cursor: pointer;
    }
  </style>
  <script>
    (function() {
      const dialog = document.getElementById('rsvpDialog');
      const closeBtn = document.getElementById('rsvpDialogClose');
      if (!dialog) return;

      // Close handler for the button
      closeBtn?.addEventListener('click', () => {
        if (typeof dialog.close === 'function') {
          dialog.close();
        } else {
          dialog.style.display = 'none';
        }
      });

      // If dialog element doesn't support showModal, provide a simple fallback
      if (typeof dialog.showModal !== 'function') {
        // Replace showModal with a fallback implementation
        dialog.showModal = function() {
          dialog.style.position = 'fixed';
          dialog.style.left = '50%';
          dialog.style.top = '50%';
          dialog.style.transform = 'translate(-50%, -50%)';
          dialog.style.zIndex = '9999';
          dialog.style.display = 'block';
        };
        dialog.close = function() {
          dialog.style.display = 'none';
        };
      }
    })();
  </script>
</div>
