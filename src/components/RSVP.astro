<div class="card">
  <h1>Confirma tu presencia!</h1>
  <form action="https://docs.google.com/forms/d/e/1FAIpQLSdm7Yab1LKQO7hO5jjZpGL3qbDHN-WKUDuxtWAE2L4Xfitzug/formResponse" method="post" class="form-grid">
    <div class="field">
      <label for="nombre">Nombre Completo</label>
      <input name="entry.1777691097" id="nombre" />
    </div>
    <div class="field">
      <label for="n_adultos">Cantidad Adultos</label>
      <input name="entry.1572898739" id="n_adultos" />
    </div>
    <div class="field">
      <label for="n_menores">Cantidad Menores (hasta 10 años)</label>
      <input name="entry.384189581" id="n_menores" />
    </div>
    <div class="field">
      <label for="restricciones">Restricciones Alimentarias</label>
      <select name="entry.1067818" id="restricciones">
        <option value="Ninguna">Ninguna</option>
        <option value="Celiaco">Celiaco</option>
        <option value="Vegetariano">Vegetariano</option>
        <option value="Vegano">Vegano</option>
        <option value="__other_option__">Otro</option>
      </select>
    </div>
    <div class="field" id="restricciones-otro-container" style="display:none;">
      <label for="restricciones-otro">Especificar otra restricción</label>
      <input name="entry.1067818.other_option_response" id="restricciones-otro" placeholder="Detalle la restricción" />
    </div>
    <div class="field submit-row">
      <button type="submit">Enviar</button>
    </div>
  </form>
  <script>
    const restriccionesSelect = document.getElementById('restricciones');
    const otroContainer = document.getElementById('restricciones-otro-container');
    restriccionesSelect?.addEventListener('change', () => {
      if (restriccionesSelect.value === 'otro') {
        otroContainer.style.display = 'block';
      } else {
        otroContainer.style.display = 'none';
      }
    });
  </script>

  <style>
    .card {
      display: flex;
      flex-direction: column;
      gap: clamp(10px, 2vw, 30px);
      padding: clamp(10px, 2vw, 30px);
      justify-content: center;
      align-items: center;
      text-align: center;
      background: #ebdec7;
    }
    .card h1 {
      margin: 0;
      font-family: 'Fraunces', serif;
      font-size: clamp(1rem, 14vw, 8vh);
      line-height: 1;
    }
    .form-grid {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      width: min(100%, 560px);
      align-items: stretch;
    }
    .field {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
      width: 100%;
    }
    .field label {
      font-family: 'Fraunces', serif;
      font-size: clamp(1rem, 3vw, 1.4rem);
      text-align: left;
    }
    .field input,
    .field select {
      width: 90%;
      padding: 0.9rem 1rem;
      border-radius: 12px;
      border: 1px solid rgba(0, 0, 0, 0.15);
      font-family: 'Fraunces', serif;
      font-size: clamp(1rem, 3vw, 1.2rem);
      background: white;
    }
    .submit-row {
      display: flex;
      justify-content: center;
      width: 100%;
    }
    .submit-row button {
      width: 100%;
      padding: 1rem;
      border: none;
      border-radius: 12px;
      background: #f1ca87;
      font-family: 'Fraunces', serif;
      font-size: clamp(1rem, 3vw, 1.2rem);
      cursor: pointer;
    }
    .submit-row button:hover {
      opacity: 0.95;
    }
  </style>
</div>
