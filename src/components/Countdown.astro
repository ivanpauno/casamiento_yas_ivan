<div class="event-date">
  <div class="date-wrapper">
    <div class="date-line">
      <span class="lined">Octubre</span>
      <span class="dayNumber">24</span>
      <span class="lined">2026</span>
    </div>
    <div class="weekday">Sábado</div>
  </div>
</div>

<div class="counter">
    <div class="circle-container">
      <div class="circle" id="days">0</div>
      <div class="text">DÍAS</div>
    </div>
    <div class="circle-container">
      <div class="circle" id="hours">0</div>
      <div class="text">HORAS</div>
    </div>
    <div class="circle-container">
      <div class="circle" id="minutes">0</div>
      <div class="text">MINUTOS</div>
    </div>
</div>

<style>
    .event-date {
        margin-bottom: 0vw;
    }

    .date-wrapper {
        width: 300px;
        margin: 0 auto;
        text-align: center;
        font-family: "GlacialIndiferenceRegular", sans-serif;
    }

    .weekday {
        font-family: "BeautifulDeliciousScript", sans-serif;
        font-size: 30vw;
        letter-spacing: 1px;
        margin-bottom: 0vw;
        text-transform: none;
    }

    .date-line {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0vw;
    }

    .lined {
        display: inline-block;
        border-top: .1vh solid #5c5448;
        border-bottom: .1vh solid #5c5448;
        padding: 0 4vw;
        font-family: "GlacialIndiferenceRegular", sans-serif;
        font-size: 10vw;
    }

    .dayNumber {
        font-family: "BeautifulDeliciousScript", cursive;
        font-size: 25vw;
        line-height: 1;
        padding: 0 2vw;
    }

    .counter {
        align-items: center;
        display: flex;
        justify-content: center;
    }

    .circle-container {
        align-items: center;
        display: flex;
        flex-direction: column;
    }

    .circle {
        align-items: center;
        border-radius: 50%;
        background-color: #ffffffff;
        color: #000;
        display: flex;
        font-size: 12vw;
        justify-content: center;
        height: 10vw;
        margin: 0px 4vw;
        width: 10vw;
    }

    .text {
        text-align: center;
        font-size: 5rem;
        margin: 5px 0;
    }

    @media only screen and (max-width: 768px) {
        .circle {
            height: 8vh;
            width: 8vh;
        }

        .text {
            font-size: 5vw;
        }
    }
</style>

<script>
    function updateCounter(): void {
        const now: Date = new Date();
        const eventDate: Date = new Date("2026-10-24T19:00:00"); // Fecha del evento

        const timeLeft: number = eventDate.getTime() - now.getTime();

        const days: number = Math.floor(timeLeft / (1000 * 60 * 60 * 24));
        const hours: number = Math.floor((timeLeft % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes: number = Math.floor((timeLeft % (1000 * 60 * 60)) / (1000 * 60));

        if (days >= 0) {
            document.getElementById("days")!.innerText = days.toString();
            document.getElementById("hours")!.innerText = hours.toString();
            document.getElementById("minutes")!.innerText = minutes.toString();
        } else {
            document.getElementById("days")!.innerText = "0";
            document.getElementById("hours")!.innerText = "0";
            document.getElementById("minutes")!.innerText = "0";
        }
    }

    setInterval(updateCounter, 1000);
</script>