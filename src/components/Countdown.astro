---
import { Image } from 'astro:assets';

import calendar from '../images/iconos/calendario.png';
import clock from '../images/iconos/reloj.png';
---

<div class="countdown">
    <div class="event-date">
        <Image src={calendar} alt="calendar" width={600} sizes="(max-width: 600px) 600px, (max-width: 1200px) 1200px, 1920px" />
        <div class="date-wrapper">
            <div class="date-line">
                <span class="lined">Octubre</span>
                <span class="cursive">      24      </span>
                <span class="lined">2026</span>
            </div>
        </div>
    </div>

    <div class="event-time">
        <Image src={clock} alt="clock" width={600} sizes="(max-width: 600px) 600px, (max-width: 1200px) 1200px, 1920px" />
        <div>
            <span class="cursive">   19:00   </span>
        </div>
    </div>

    <div class="counter">
        <div class="circle-container">
            <div class="circle" id="days">0</div>
            <div class="text">DÍAS</div>
        </div>
        <div class="circle-container">
            <div class="circle" id="hours">0</div>
            <div class="text">HORAS</div>
        </div>
        <div class="circle-container">
            <div class="circle" id="minutes">0</div>
            <div class="text">MINUTOS</div>
        </div>
    </div>
</div>

<style>
    .countdown {
        background: var(--card-gradient);
        display: flex;
        flex-direction: column;
        gap: clamp(5px, 1vw, 15px);
        padding: clamp(5px, 1vw, 15px);
        justify-content: center;
        justify-items: center;
        align-content: center;
        align-items: center;
        text-align: center;
        font-family: var(--font-heading);
    }
    .event-date {
        display: flex;
        flex-direction: row;
        justify-items: center;
        justify-content: center;
        align-content: center;
        align-items: center;
        text-align: center;
    }
    .event-date img {
        height: calc(2 * clamp(1rem, 14vw, 6svh));
        width: auto;
        position: relative;
        top: 0%;
    }

    .event-time {
        display: flex;
        flex-direction: row;
        justify-items: center;
        justify-content: center;
        align-content: center;
        align-items: center;
        text-align: center;
    }
    .event-time img {
        height: calc(2 * clamp(1rem, 14vw, 6svh));
        width: calc(2 * clamp(1rem, 14vw, 6svh));
        object-fit: contain;
        position: relative;
        top: 0%;
        display: block;
    }

    .lined {
        display: inline-block;
        border-top: .1svh solid #5c5448;
        border-bottom: .1svh solid #5c5448;
        padding: 0 1svw;
        font-size: clamp(1rem, 14vw, 6svh);
    }

    .cursive {
        font-size: clamp(1rem, 14vw, 6svh);
    }

    .counter {
        align-items: center;
        display: flex;
        justify-content: center;
        padding-top: clamp(30px, 6vw, 90px);
    }

    .circle-container {
        align-items: center;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
    }

    .circle {
        align-items: center;
        border-radius: 50%;
        background-color: #f8efe0;
        border: 1px solid rgba(0, 0, 0, 0.15);
        box-shadow: 0 14px 28px rgba(0, 0, 0, 0.12);
        color: #000;
        display: flex;
        font-size: clamp(1.5rem, 6vw, 3rem);
        justify-content: center;
        height: min(10vw, 140px);
        margin: 0px 4vw;
        width: min(10vw, 140px);
        min-height: 96px;
        min-width: 96px;
    }

    .text {
        text-align: center;
        font-size: clamp(1rem, 2vw, 1.2rem);
        margin: 0;
        letter-spacing: 0.08em;
    }

    @media only screen and (max-width: 768px) {
        .circle {
            height: 10vw;
            width: 10vw;
        }
        span {
            display: block;
        }

        .text {
            font-size: 5vw;
        }
    }
</style>

<script>
    function updateCounter(): void {
        const now: Date = new Date();
        const eventDate: Date = new Date("2026-10-24T19:00:00"); // Fecha del evento

        const timeLeft: number = eventDate.getTime() - now.getTime();

        const days: number = Math.floor(timeLeft / (1000 * 60 * 60 * 24));
        const hours: number = Math.floor((timeLeft % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes: number = Math.floor((timeLeft % (1000 * 60 * 60)) / (1000 * 60));

        if (days >= 0) {
            document.getElementById("days")!.innerText = days.toString();
            document.getElementById("hours")!.innerText = hours.toString();
            document.getElementById("minutes")!.innerText = minutes.toString();
        } else {
            document.getElementById("days")!.innerText = "0";
            document.getElementById("hours")!.innerText = "0";
            document.getElementById("minutes")!.innerText = "0";
        }
    }

    setInterval(updateCounter, 1000);
</script>