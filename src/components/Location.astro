---
const { place = 'Salón Principal, Ciudad'} = Astro.props;
---
<div class="card">
  <h2 style="margin:0 0 8px 0">Lugar</h2>
  <p style="margin:0 0 12px 0;color:var(--muted)">{place}</p>
  <div style="width:100%;height:300px;border-radius:8px;overflow:hidden">
    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3288.197937514908!2d-58.48199702253961!3d-34.49786587299244!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bcb16e707680b1%3A0x74a58805a211ea3e!2sC%C3%ADrculo%20Olivos%20Eventos!5e0!3m2!1ses-419!2sar!4v1780848860946!5m2!1ses-419!2sar" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
  </div>
</div>
